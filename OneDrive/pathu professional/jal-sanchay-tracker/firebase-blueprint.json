{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User preferences and system setup parameters",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "roofArea": { "type": "number", "description": "Roof area in sq. meters" },
        "tankCapacity": { "type": "number", "description": "Tank capacity in liters" },
        "setupCompleted": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "roofArea", "tankCapacity", "setupCompleted"]
    },
    "RainfallEntry": {
      "title": "Rainfall Entry",
      "description": "Daily rainfall measurement and calculated collection",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "description": "ISO date string" },
        "amount": { "type": "number", "description": "Rainfall in mm" },
        "waterCollected": { "type": "number", "description": "Liters of water harvested" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "amount", "waterCollected", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and setup data"
    },
    "/rainfallEntries/{entryId}": {
      "schema": "RainfallEntry",
      "description": "Individual rainfall logs"
    }
  }
}
