<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="serif"
            android:text="One-time Setup"
            android:textColor="@color/brand_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Please provide your harvester details."
            android:textColor="@color/brand_muted"
            android:textSize="14sp" />

        <!-- Roof Area -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roof Area (sq.m)"
            android:textColor="@color/brand_text"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_roof_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/brand_primary"
            android:hint="e.g. 120"
            android:inputType="numberDecimal"
            android:padding="12dp" />

        <!-- Tank Capacity -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tank Capacity (Liters)"
            android:textColor="@color/brand_text"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_tank_capacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="40dp"
            android:backgroundTint="@color/brand_primary"
            android:hint="e.g. 5000"
            android:inputType="numberDecimal"
            android:padding="12dp" />

        <!-- Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_finish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Complete Setup"
            android:textAllCaps="false"
            app:cornerRadius="16dp" />

    </LinearLayout>

</ScrollView>