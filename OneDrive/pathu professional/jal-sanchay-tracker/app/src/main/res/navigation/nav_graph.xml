<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/splashFragment">

    <!-- 🔹 Splash Screen -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.jalsanchay.tracker.ui.SplashFragment"
        android:label="Splash">

        <action
            android:id="@+id/action_splash_to_setup"
            app:destination="@id/setupFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- 🔹 Setup Screen -->
    <fragment
        android:id="@+id/setupFragment"
        android:name="com.jalsanchay.tracker.ui.SetupFragment"
        android:label="Setup">

        <action
            android:id="@+id/action_setup_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/setupFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- 🔹 Dashboard -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.jalsanchay.tracker.ui.DashboardFragment"
        android:label="Dashboard">

        <!-- Go to Entry -->
        <action
            android:id="@+id/action_dashboardFragment_to_entryFragment"
            app:destination="@id/entryFragment" />

        <!-- Go to Setup (optional) -->
        <action
            android:id="@+id/action_dashboard_to_setup"
            app:destination="@id/setupFragment" />

        <!-- 🔥 NEW: Go to Analytics -->
        <action
            android:id="@+id/action_dashboard_to_analytics"
            app:destination="@id/analyticsFragment" />

    </fragment>

    <!-- 🔹 Entry Screen -->
    <fragment
        android:id="@+id/entryFragment"
        android:name="com.jalsanchay.tracker.ui.EntryFragment"
        android:label="Entry">

        <action
            android:id="@+id/action_entry_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/entryFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- 🔹 Analytics Screen -->
    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.jalsanchay.tracker.ui.AnalyticsFragment"
        android:label="Analytics" />

</navigation>